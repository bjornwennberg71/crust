// threads: spawn(fn_or_closure) returns a thread handle; join() waits on it

void worker()
{
    println("hello from a named function thread");
}

void main()
{
    // spawn a plain function
    thread t1 = spawn(worker);

    // spawn a closure
    thread t2 = spawn(lambda() {
        for (int i = 0; i < 3; i++)
        {
            println("closure thread: {}", i);
            sleep_ms(10);
        }
    });

    // captures are moved into the thread automatically — no `move` keyword.
    // `greeting` belongs to the thread after this line; share via arc<T> if
    // both sides need it.
    string greeting = "captured";
    thread t3 = spawn(lambda() {
        println("thread owns: {}", greeting);
    });

    t1.join();
    t2.join();
    t3.join();
    println("all threads joined");
}
