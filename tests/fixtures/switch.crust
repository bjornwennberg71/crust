function describe(int n): int
{
    switch (n)
    {
        case 1:
        {
            return 10;
        }
        case 2:
        {
            return 20;
        }
        default:
        {
            return 0;
        }
    }
}

function main()
{
    int a = describe(1);
    int b = describe(2);
    int c = describe(99);
}
